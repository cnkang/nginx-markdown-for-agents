# tools/build_release/Dockerfile.musl
ARG OS_BASE=alpine:3.20
FROM ${OS_BASE}

RUN set -eux; \
    retry() { \
        attempts="$1"; \
        shift; \
        count=1; \
        while :; do \
            "$@" && break; \
            if [ "$count" -ge "$attempts" ]; then \
                echo "command failed after ${attempts} attempts: $*" >&2; \
                exit 1; \
            fi; \
            sleep "$((count * 5))"; \
            count=$((count + 1)); \
        done; \
    }; \
    retry 5 apk add --no-cache \
        build-base \
        ca-certificates \
        curl \
        linux-headers \
        openssl-dev \
        pcre-dev \
        python3 \
        zlib-dev; \
    retry 5 curl --proto '=https' --tlsv1.2 -fsSL https://sh.rustup.rs -o /tmp/rustup-init.sh; \
    retry 5 sh /tmp/rustup-init.sh -y; \
    rm -f /tmp/rustup-init.sh; \
    retry 5 /root/.cargo/bin/cargo install cbindgen
ENV PATH="/root/.cargo/bin:${PATH}"

RUN update-ca-certificates

ARG NGINX_VERSION=1.28.2

WORKDIR /build
COPY packaging/nginx-checksums.yaml /src/packaging/nginx-checksums.yaml
RUN set -eux; \
    retry() { \
        attempts="$1"; \
        shift; \
        count=1; \
        while :; do \
            "$@" && break; \
            if [ "$count" -ge "$attempts" ]; then \
                echo "command failed after ${attempts} attempts: $*" >&2; \
                exit 1; \
            fi; \
            sleep "$((count * 5))"; \
            count=$((count + 1)); \
        done; \
    }; \
    retry 5 curl --proto '=https' --tlsv1.2 -fsSL \
        -o /tmp/nginx.tar.gz \
        "https://nginx.org/download/nginx-${NGINX_VERSION}.tar.gz"; \
    CHECKSUM_FILE="/src/packaging/nginx-checksums.yaml"; \
    if [ -f "$${CHECKSUM_FILE}" ]; then \
        EXPECTED_SHA256=$$(python3 -c "import yaml; data=yaml.safe_load(open('$${CHECKSUM_FILE}')); print(data['checksums']['${NGINX_VERSION}'])" 2>/dev/null || echo ""); \
        if [ -n "$${EXPECTED_SHA256}" ] && [ "$${EXPECTED_SHA256##*PLACEHOLDER*}" = "" ]; then \
            echo "WARNING: SHA256 for nginx ${NGINX_VERSION} is a placeholder, skipping verification"; \
        elif [ -n "$${EXPECTED_SHA256}" ]; then \
            ACTUAL_SHA256=$$(sha256sum /tmp/nginx.tar.gz | cut -d' ' -f1); \
            if [ "$${ACTUAL_SHA256}" != "$${EXPECTED_SHA256}" ]; then \
                echo "ERROR: SHA256 mismatch for nginx tarball" >&2; exit 1; \
            fi; \
            echo "SHA256 verified for nginx tarball"; \
        fi; \
    else \
        echo "WARNING: packaging/nginx-checksums.yaml not found, skipping SHA256 verification"; \
    fi; \
    tar xzf /tmp/nginx.tar.gz; \
    rm -f /tmp/nginx.tar.gz

COPY Makefile /src/Makefile
COPY components/rust-converter /src/components/rust-converter
COPY components/nginx-module /src/components/nginx-module

WORKDIR /src
RUN rm -rf components/rust-converter/target \
    && make build

WORKDIR /build/nginx-${NGINX_VERSION}
RUN ./configure --with-compat --add-dynamic-module=/src/components/nginx-module \
    && make modules \
    && mkdir /out \
    && cp objs/ngx_http_markdown_filter_module.so /out/ngx_http_markdown_filter_module.so

USER 65532:65532
