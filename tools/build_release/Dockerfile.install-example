# Example Dockerfile showing optimized installation
# This demonstrates how to use the install script efficiently in Docker builds

ARG NGINX_VERSION=1.26.3
ARG MODULE_REF=v0.1.0
ARG INSTALL_SHA256
FROM nginx:${NGINX_VERSION}-alpine

# Install dependencies and install the module in one layer.
RUN apk add --no-cache \
    bash \
    curl \
    gzip \
    python3 \
    tar \
    && curl --proto '=https' --tlsv1.2 -fsSL "https://raw.githubusercontent.com/cnkang/nginx-markdown-for-agents/${MODULE_REF}/tools/install.sh" -o /tmp/install.sh \
    && test -n "${INSTALL_SHA256}" \
    && echo "${INSTALL_SHA256}  /tmp/install.sh" | sha256sum -c - \
    && chmod +x /tmp/install.sh \
    && SKIP_ROOT_CHECK=1 /tmp/install.sh \
    && rm -f /tmp/install.sh

# OR: If you need a specific version
# ARG MODULE_REF=v0.1.0

# OR: For local development/testing, copy only the install script
# COPY tools/install.sh /tmp/install.sh
# RUN SKIP_ROOT_CHECK=1 bash /tmp/install.sh && rm /tmp/install.sh

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
