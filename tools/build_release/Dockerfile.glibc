# tools/build_release/Dockerfile.glibc
ARG OS_BASE=almalinux@sha256:d2515c769e7b73f95c4fde38c0a505336ff38f14990c0b7253b77060a049a743
FROM ${OS_BASE}

ARG TARGETARCH

COPY packaging/checksums.sha256 /src/packaging/checksums.sha256
COPY packaging/scripts/install-verified-rustup.sh /src/packaging/scripts/install-verified-rustup.sh
COPY packaging/scripts/verify-checksum.sh /src/packaging/scripts/verify-checksum.sh

RUN set -eux; \
    retry() { \
        attempts="$1"; \
        shift; \
        count=1; \
        while :; do \
            "$@" && break; \
            if [ "$count" -ge "$attempts" ]; then \
                echo "command failed after ${attempts} attempts: $*" >&2; \
                exit 1; \
            fi; \
            sleep "$((count * 5))"; \
            count=$((count + 1)); \
        done; \
    }; \
    dnf install -y \
        gcc \
        make \
        ca-certificates \
        curl-minimal \
        pcre2-devel \
        openssl-devel \
        python3 \
        zlib-devel \
        brotli-devel \
        tar \
        gzip \
        findutils; \
    dnf clean all; \
    arch="${TARGETARCH:-$(uname -m)}"; \
    case "${arch}" in \
        amd64|x86_64) rustup_arch=amd64 ;; \
        arm64|aarch64) rustup_arch=arm64 ;; \
        *) echo "unsupported Rust bootstrap architecture: ${arch}" >&2; exit 1 ;; \
    esac; \
    chmod +x /src/packaging/scripts/install-verified-rustup.sh \
        /src/packaging/scripts/verify-checksum.sh; \
    /src/packaging/scripts/install-verified-rustup.sh \
        --arch "${rustup_arch}" \
        --toolchain none \
        --checksums /src/packaging/checksums.sha256
ENV PATH="/root/.cargo/bin:${PATH}"

ARG NGINX_VERSION=1.26.3

# Pin the Rust toolchain to the repository's rust-toolchain.toml so release
# binaries are built with the same compiler as the package artifacts
# (AGENTS.md Rule 13: release builds must not float on `stable`).  rustup
# auto-installs the channel named in this file on first cargo invocation.
COPY rust-toolchain.toml /src/rust-toolchain.toml
RUN set -eux; \
    retry() { \
        attempts="$1"; \
        shift; \
        count=1; \
        while :; do \
            "$@" && break; \
            if [ "$count" -ge "$attempts" ]; then \
                echo "command failed after ${attempts} attempts: $*" >&2; \
                exit 1; \
            fi; \
            sleep "$((count * 5))"; \
            count=$((count + 1)); \
        done; \
    }; \
    cd /src; \
    retry 5 rustup toolchain install; \
    retry 5 cargo install cbindgen --version 0.29.2 --locked

WORKDIR /build
RUN set -eux; \
    retry() { \
        attempts="$1"; \
        shift; \
        count=1; \
        while :; do \
            "$@" && break; \
            if [ "$count" -ge "$attempts" ]; then \
                echo "command failed after ${attempts} attempts: $*" >&2; \
                exit 1; \
            fi; \
            sleep "$((count * 5))"; \
            count=$((count + 1)); \
        done; \
    }; \
    retry 5 curl --proto '=https' --tlsv1.2 -fsSL \
        -o /tmp/nginx.tar.gz \
        "https://nginx.org/download/nginx-${NGINX_VERSION}.tar.gz"; \
    chmod +x /src/packaging/scripts/verify-checksum.sh; \
    /src/packaging/scripts/verify-checksum.sh \
        -f /tmp/nginx.tar.gz \
        -i "nginx-${NGINX_VERSION}" \
        -c /src/packaging/checksums.sha256; \
    tar xzf /tmp/nginx.tar.gz; \
    rm -f /tmp/nginx.tar.gz

# Copy only files required for module build.
COPY Makefile /src/Makefile
COPY components/rust-converter /src/components/rust-converter
COPY components/nginx-module /src/components/nginx-module

WORKDIR /src
RUN rm -rf components/rust-converter/target \
    && make build

WORKDIR /build/nginx-${NGINX_VERSION}
ENV NGX_MARKDOWN_BROTLI_STREAMING=on
RUN ./configure --with-compat --add-dynamic-module=/src/components/nginx-module \
    && make modules \
    && mkdir /out \
    && cp objs/ngx_http_markdown_filter_module.so /out/ngx_http_markdown_filter_module.so \
    && echo "--- Verifying libbrotlidec linkage ---" \
    && readelf -d /out/ngx_http_markdown_filter_module.so | grep -i brotli \
    && echo "--- libbrotlidec linkage confirmed ---"

USER 65532:65532
