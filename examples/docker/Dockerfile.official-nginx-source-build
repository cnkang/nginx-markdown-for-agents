# syntax=docker/dockerfile:1.7

ARG NGINX_IMAGE=nginx:mainline
ARG MODULE_REPO=https://github.com/cnkang/nginx-markdown-for-agents.git
ARG MODULE_REF=main
ARG MODULE_SHA=

FROM ${NGINX_IMAGE} AS build

ARG MODULE_REPO
ARG MODULE_REF
ARG MODULE_SHA
ARG TARGETARCH

ENV RUSTUP_HOME=/opt/rust/rustup
ENV CARGO_HOME=/opt/rust/cargo
ENV PATH=/opt/rust/cargo/bin:${PATH}

COPY packaging/checksums.sha256 /tmp/rustup-bootstrap/checksums.sha256
COPY packaging/scripts/install-verified-rustup.sh /tmp/rustup-bootstrap/install-verified-rustup.sh
COPY packaging/scripts/verify-checksum.sh /tmp/rustup-bootstrap/verify-checksum.sh

RUN set -eux; \
    if command -v apt-get >/dev/null 2>&1; then \
      apt-get update; \
      DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        bash \
        build-essential \
        ca-certificates \
        curl \
        git \
        libpcre2-dev \
        libssl-dev \
        pkg-config \
        python3 \
        zlib1g-dev; \
      rm -rf /var/lib/apt/lists/*; \
    elif command -v apk >/dev/null 2>&1; then \
      apk add --no-cache \
        bash \
        build-base \
        ca-certificates \
        curl \
        git \
        linux-headers \
        nginx-mod-dev \
        openssl-dev \
        pcre2-dev \
        pkgconf \
        python3 \
        zlib-dev; \
    else \
      echo "Unsupported package manager in base image"; \
      exit 1; \
    fi

RUN --mount=type=cache,target=/opt/rust/rustup,sharing=locked \
    --mount=type=cache,target=/opt/rust/cargo/registry,sharing=locked \
    --mount=type=cache,target=/opt/rust/cargo/git,sharing=locked \
    set -eux; \
    if ! command -v rustup >/dev/null 2>&1; then \
      arch="${TARGETARCH:-$(uname -m)}"; \
      if command -v apk >/dev/null 2>&1; then \
        rustup_libc=musl; \
      else \
        rustup_libc=gnu; \
      fi; \
      case "${arch}" in \
        amd64|x86_64) rustup_arch=amd64 ;; \
        arm64|aarch64) rustup_arch=arm64 ;; \
        *) echo "Unsupported Rust bootstrap architecture: ${arch}" >&2; exit 1 ;; \
      esac; \
      chmod +x /tmp/rustup-bootstrap/install-verified-rustup.sh \
        /tmp/rustup-bootstrap/verify-checksum.sh; \
      /tmp/rustup-bootstrap/install-verified-rustup.sh \
        --arch "${rustup_arch}" \
        --libc "${rustup_libc}" \
        --toolchain stable \
        --checksums /tmp/rustup-bootstrap/checksums.sha256; \
      rm -rf /tmp/rustup-bootstrap; \
    fi; \
    arch="$(uname -m)"; \
    if command -v apk >/dev/null 2>&1; then \
      libc=musl; \
    else \
      libc=gnu; \
    fi; \
    case "${arch}:${libc}" in \
      x86_64:musl) rust_target=x86_64-unknown-linux-musl ;; \
      aarch64:musl) rust_target=aarch64-unknown-linux-musl ;; \
      x86_64:gnu) rust_target=x86_64-unknown-linux-gnu ;; \
      aarch64:gnu) rust_target=aarch64-unknown-linux-gnu ;; \
      *) echo "Unsupported Rust target for ${arch}:${libc}" >&2; exit 1 ;; \
    esac; \
    rustup target add "${rust_target}"; \
    if ! command -v cbindgen >/dev/null 2>&1; then \
      cargo install cbindgen --version 0.29.2 --locked; \
    fi

RUN --mount=type=cache,target=/opt/rust/rustup,sharing=locked \
    --mount=type=cache,target=/opt/rust/cargo/registry,sharing=locked \
    --mount=type=cache,target=/opt/rust/cargo/git,sharing=locked \
    --mount=type=cache,target=/opt/cargo-target,sharing=locked \
    set -eux; \
    mkdir -p /workspace; \
    git clone "${MODULE_REPO}" /workspace/nginx-markdown-for-agents; \
    cd /workspace/nginx-markdown-for-agents; \
    if [ -n "${MODULE_SHA}" ]; then \
      git fetch --depth 1 origin "${MODULE_SHA}" || git fetch --depth 1 origin "${MODULE_REF}"; \
      git checkout --detach "${MODULE_SHA}" || git checkout --detach FETCH_HEAD; \
    elif [ -n "${MODULE_REF}" ]; then \
      git fetch --depth 1 origin "${MODULE_REF}" || true; \
      git checkout "${MODULE_REF}" || git checkout FETCH_HEAD; \
    fi; \
    nginx_version="$(nginx -v 2>&1 | sed -n 's#^nginx version: nginx/\([0-9.]*\)$#\1#p')"; \
    test -n "${nginx_version}"; \
    if command -v apk >/dev/null 2>&1 && [ -d "/usr/src/nginx-${nginx_version}" ]; then \
      nginx_src_root="/usr/src/nginx-${nginx_version}"; \
    else \
      curl -fsSL "https://nginx.org/download/nginx-${nginx_version}.tar.gz" -o /tmp/nginx.tar.gz; \
      mkdir -p /tmp/nginx-src; \
      tar -xzf /tmp/nginx.tar.gz -C /tmp/nginx-src --strip-components=1; \
      nginx_src_root="/tmp/nginx-src"; \
    fi; \
    rm -rf /workspace/nginx-markdown-for-agents/components/rust-converter/target; \
    ln -s /opt/cargo-target /workspace/nginx-markdown-for-agents/components/rust-converter/target; \
    cd /workspace/nginx-markdown-for-agents; \
    make build; \
    confargs="$(nginx -V 2>&1 | sed -n 's/^.*arguments: //p')"; \
    test -n "${confargs}"; \
    cd "${nginx_src_root}"; \
    eval "./configure --with-compat ${confargs} --add-dynamic-module=/workspace/nginx-markdown-for-agents/components/nginx-module"; \
    make -j"$(getconf _NPROCESSORS_ONLN 2>/dev/null || nproc || echo 4)" modules; \
    install -D -m 755 objs/ngx_http_markdown_filter_module.so /out/ngx_http_markdown_filter_module.so; \
    printf '%s\n' "${nginx_version}" >/out/nginx-version.txt

FROM ${NGINX_IMAGE} AS runtime

COPY --from=build /out/ngx_http_markdown_filter_module.so /etc/nginx/modules/ngx_http_markdown_filter_module.so
COPY --from=build /out/nginx-version.txt /etc/nginx/modules/ngx_http_markdown_filter_module.version

RUN set -eux; \
    printf '%s\n' \
      'load_module modules/ngx_http_markdown_filter_module.so;' \
      'worker_processes auto;' \
      'pid /tmp/nginx.pid;' \
      'events {' \
      '    worker_connections 1024;' \
      '}' \
      'http {' \
      '    include       /etc/nginx/mime.types;' \
      '    default_type  application/octet-stream;' \
      '    sendfile      on;' \
      '    keepalive_timeout 65;' \
      '    client_body_temp_path /tmp/client_temp;' \
      '    proxy_temp_path /tmp/proxy_temp;' \
      '    fastcgi_temp_path /tmp/fastcgi_temp;' \
      '    uwsgi_temp_path /tmp/uwsgi_temp;' \
      '    scgi_temp_path /tmp/scgi_temp;' \
      '' \
      '    server {' \
      '        listen 8080;' \
      '        server_name _;' \
      '        root /usr/share/nginx/html;' \
      '' \
      '        location / {' \
      '            markdown_filter on;' \
      '            markdown_accept wildcard;' \
      '            markdown_cache_validation full;' \
      '        }' \
      '    }' \
      '}' \
      > /etc/nginx/nginx.conf; \
    printf '%s\n' \
      '<!doctype html>' \
      '<html>' \
      '  <head>' \
      '    <meta charset="utf-8">' \
      '    <title>NGINX Markdown Docker Example</title>' \
      '  </head>' \
      '  <body>' \
      '    <h1>Docker Example Heading</h1>' \
      '    <p>This image compiles the markdown module from source against the official nginx image.</p>' \
      '  </body>' \
      '</html>' \
      > /usr/share/nginx/html/index.html

USER nginx

EXPOSE 8080
