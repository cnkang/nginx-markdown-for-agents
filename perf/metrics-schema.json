{
  "schema_version": "1.0.0",
  "metrics": [
    {
      "name": "p50_ms",
      "unit": "milliseconds",
      "collection": "percentile",
      "aggregation": "median",
      "direction": "lower_is_better",
      "description": "P50 latency"
    },
    {
      "name": "p95_ms",
      "unit": "milliseconds",
      "collection": "percentile",
      "aggregation": "direct",
      "direction": "lower_is_better",
      "description": "P95 latency"
    },
    {
      "name": "p99_ms",
      "unit": "milliseconds",
      "collection": "percentile",
      "aggregation": "direct",
      "direction": "lower_is_better",
      "description": "P99 latency"
    },
    {
      "name": "peak_memory_bytes",
      "unit": "bytes",
      "collection": "process_rss",
      "aggregation": "max",
      "direction": "lower_is_better",
      "description": "Peak RSS memory"
    },
    {
      "name": "req_per_s",
      "unit": "requests/second",
      "collection": "derived",
      "aggregation": "median",
      "direction": "higher_is_better",
      "description": "Throughput"
    },
    {
      "name": "input_mb_per_s",
      "unit": "MB/second",
      "collection": "derived",
      "aggregation": "median",
      "direction": "higher_is_better",
      "description": "Input throughput"
    },
    {
      "name": "stage_parse_pct",
      "unit": "percent",
      "collection": "stage_timing",
      "aggregation": "mean",
      "direction": "informational",
      "description": "Parse stage percentage"
    },
    {
      "name": "stage_convert_pct",
      "unit": "percent",
      "collection": "stage_timing",
      "aggregation": "mean",
      "direction": "informational",
      "description": "Convert stage percentage"
    },
    {
      "name": "stage_etag_pct",
      "unit": "percent",
      "collection": "stage_timing",
      "aggregation": "mean",
      "direction": "informational",
      "description": "ETag stage percentage"
    },
    {
      "name": "stage_token_pct",
      "unit": "percent",
      "collection": "stage_timing",
      "aggregation": "mean",
      "direction": "informational",
      "description": "Token stage percentage"
    },
    {
      "name": "ttfb_ms",
      "unit": "milliseconds",
      "collection": "streaming_timer",
      "aggregation": "median",
      "direction": "lower_is_better",
      "description": "Time to first Markdown byte (streaming only)"
    },
    {
      "name": "ttlb_ms",
      "unit": "milliseconds",
      "collection": "streaming_timer",
      "aggregation": "median",
      "direction": "lower_is_better",
      "description": "Time to last Markdown byte (streaming only)"
    },
    {
      "name": "cpu_time_ms",
      "unit": "milliseconds",
      "collection": "wall_clock_approx",
      "aggregation": "median",
      "direction": "lower_is_better",
      "description": "Wall-clock time consumed during conversion (approximates CPU time)"
    },
    {
      "name": "flush_count",
      "unit": "count",
      "collection": "streaming_counter",
      "aggregation": "median",
      "direction": "informational",
      "description": "Number of flush points during streaming conversion"
    },
    {
      "name": "fallback_rate",
      "unit": "ratio",
      "collection": "streaming_counter",
      "aggregation": "mean",
      "direction": "lower_is_better",
      "description": "Rate of pre-commit fallback to full-buffer"
    }
  ],
  "sample_tiers": [
    {
      "name": "small",
      "target_size": "~0.4KB",
      "source": "tests/corpus/simple/basic.html",
      "generation": "direct"
    },
    {
      "name": "medium",
      "target_size": "~10KB",
      "source": "tests/corpus/complex/blog-post.html",
      "generation": "repeat_to_size(10240)"
    },
    {
      "name": "medium-front-matter",
      "target_size": "~10KB",
      "source": "tests/corpus/complex/blog-post.html",
      "generation": "repeat_to_size(10240) + front_matter=true"
    },
    {
      "name": "large-1m",
      "target_size": "~1MB",
      "source": "tests/corpus/complex/blog-post.html",
      "generation": "repeat_to_size(1048576)"
    },
    {
      "name": "large-100k",
      "target_size": "~100KB",
      "source": "tools/corpus/generate_large_samples.sh",
      "generation": "script(generate_large_samples.sh --tier large-100k)",
      "variants": [
        "plain-html",
        "front-matter",
        "token-estimation",
        "nested-tables-code"
      ]
    },
    {
      "name": "large-5m",
      "target_size": "~5MB",
      "source": "tools/corpus/generate_large_samples.sh",
      "generation": "script(generate_large_samples.sh --tier large-5m)",
      "variants": [
        "plain-html",
        "front-matter",
        "token-estimation",
        "nested-tables-code"
      ]
    },
    {
      "name": "large-10m",
      "target_size": "~10MB",
      "source": "tools/corpus/generate_large_samples.sh",
      "generation": "script(generate_large_samples.sh --tier large-10m)",
      "streaming_focus": true
    },
    {
      "name": "extra-large-64m",
      "target_size": "~64MB",
      "source": "tools/corpus/generate_large_samples.sh",
      "generation": "script(generate_large_samples.sh --tier extra-large-64m)",
      "streaming_focus": true,
      "description": "Bounded-memory critical validation point"
    },
    {
      "name": "streaming-chunked",
      "target_size": "~1KB (seed fixture, expand via repeat for perf testing)",
      "source": "tests/corpus/streaming-perf/chunked-mixed.html",
      "generation": "fixed fixture",
      "streaming_focus": true
    },
    {
      "name": "streaming-tables-heavy",
      "target_size": "~1KB (seed fixture, expand via repeat for perf testing)",
      "source": "tests/corpus/streaming-perf/tables-heavy.html",
      "generation": "fixed fixture",
      "streaming_focus": true,
      "description": "Table-heavy HTML expected to trigger pre-commit fallback"
    },
    {
      "name": "streaming-code-heavy",
      "target_size": "~2KB (seed fixture, expand via repeat for perf testing)",
      "source": "tests/corpus/streaming-perf/code-heavy.html",
      "generation": "fixed fixture",
      "streaming_focus": true
    },
    {
      "name": "streaming-malformed",
      "target_size": "~1KB (seed fixture, expand via repeat for perf testing)",
      "source": "tests/corpus/streaming-perf/malformed-large.html",
      "generation": "fixed fixture",
      "streaming_focus": true
    },
    {
      "name": "streaming-mixed-charset",
      "target_size": "~1KB (seed fixture, expand via repeat for perf testing)",
      "source": "tests/corpus/streaming-perf/mixed-charset.html",
      "generation": "fixed fixture",
      "streaming_focus": true
    }
  ]
}
