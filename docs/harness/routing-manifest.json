{
  "version": 1,
  "codex_first": true,
  "truth_surfaces": {
    "contract": [
      "AGENTS.md"
    ],
    "harness": [
      "docs/harness/README.md",
      "docs/harness/core.md",
      "docs/harness/routing-manifest.md",
      "docs/harness/routing-manifest.json",
      "docs/harness/risk-packs/README.md"
    ],
    "canonical_docs": [
      "docs/architecture/README.md",
      "docs/testing/README.md",
      "docs/DOCUMENTATION_DUPLICATION_POLICY.md"
    ],
    "optional_adapters": [
      ".kiro/steering/product.md",
      ".kiro/steering/structure.md",
      ".kiro/steering/tech.md"
    ]
  },
  "status_semantics": [
    "PASS",
    "FAIL",
    "SKIP_NOT_PRESENT",
    "WARN_NEEDS_AUTHOR_REVIEW"
  ],
  "spec_resolver": {
    "priority": [
      "agents-baseline",
      "user-task",
      "active-spec-pointer",
      "agents-workflow",
      "harness-core",
      "replay-calibration"
    ],
    "priority_semantics": "agents-baseline (NGINX Baseline, Rules) cannot be overridden by user-task. user-task has priority over agents-workflow and harness-core for task scope and implementation intent.",
    "pointer_candidates": [
      ".kiro/active-spec.json",
      ".kiro/active-spec.txt"
    ],
    "multiple_spec_policy": "explain-current-choice",
    "conflict_policy": "stop-and-confirm"
  },
  "verification_families": {
    "harness-sync": {
      "phase": "cheap-blocker",
      "commands": [
        "make harness-check"
      ]
    },
    "docs-tooling": {
      "phase": "cheap-blocker",
      "commands": [
        "make docs-check"
      ]
    },
    "harness-security": {
      "phase": "focused-semantic",
      "commands": [
        "make harness-security-checks",
        "PYTHONPATH=. pytest -q tools/perf/tests"
      ]
    },
    "security-static": {
      "phase": "cheap-blocker",
      "commands": [
        "make security-static"
      ]
    },
    "supply-chain": {
      "phase": "report-oriented-visibility",
      "commands": [
        "make supply-chain"
      ],
      "notes": "local command requires trivy and syft; GitHub workflow runs PR/push/scheduled/manual report-oriented visibility checks"
    },
    "rust-streaming": {
      "phase": "focused-semantic",
      "commands": [
        "make test-rust-streaming"
      ]
    },
    "nginx-streaming": {
      "phase": "focused-semantic",
      "commands": [
        "make test-nginx-unit-streaming"
      ]
    },
    "nginx-protocol": {
      "phase": "focused-semantic",
      "commands": [
        "make test-nginx-unit",
        "make test-nginx-integration"
      ]
    },
    "ffi-boundary": {
      "phase": "focused-semantic",
      "commands": [
        "make build",
        "make test-rust"
      ]
    },
    "observability-metrics": {
      "phase": "focused-semantic",
      "commands": [
        "make docs-check",
        "make release-gates-check"
      ]
    },
    "v070-gates": {
      "phase": "focused-semantic",
      "commands": [
        "make release-gates-check-070",
        "make test-rust",
        "make check-headers"
      ]
    },
    "v080-gates": {
      "phase": "focused-semantic",
      "commands": [
        "make release-gates-check-080"
      ]
    },
    "v090-gates": {
      "phase": "focused-semantic",
      "commands": [
        "make release-gates-check-090"
      ]
    },
    "v091-gates": {
      "phase": "focused-semantic",
      "commands": [
        "make release-gates-check-091",
        "make perf-evidence-check"
      ],
      "notes": "0.9.1 release gate: blocking performance evidence gate for RC tags; perf-evidence-check is non-blocking report-only mode"
    },
    "release-governance": {
      "phase": "focused-semantic",
      "commands": [
        "make release-gates-check-080",
        "make release-gates-check",
        "make release-gates-check-strict",
        "make release-gates-check-055"
      ]
    },
    "release-manifest": {
      "phase": "focused-semantic",
      "commands": [
        "python3 packaging/scripts/test_release_manifest.py",
        "make release-gates-check"
      ],
      "notes": "Validates release-manifest.json generation, validation, and path traversal protection (Rule 54)"
    },
    "version-consistency": {
      "phase": "focused-semantic",
      "commands": [
        "bash tools/harness/detect_version_consistency.sh",
        "make harness-security-checks"
      ],
      "notes": "Validates active release version consistency across source, chart, internal dependencies, and docs (Rule 55)"
    },
    "complexity": {
      "phase": "cheap-blocker",
      "commands": [
        "make complexity-check"
      ],
      "notes": "Runs lizard (CCN/length/params) on C/Rust/Python, complexipy (cognitive) on Python, shellcheck on shell. Baseline-gated: new violations fail, existing baseline violations that worsen produce warnings. See docs/harness/rules/complexity.md."
    },
    "regex-security": {
      "phase": "cheap-blocker",
      "commands": [
        "make regex-security-check"
      ],
      "notes": "AST-based ReDoS and regex safety detection for Python and Rust. Runs detect_regex_safety.py --strict plus unit and shell tests. See docs/harness/rules/parser-regex.md."
    },
    "runtime-e2e": {
      "phase": "umbrella",
      "commands": [
        "make verify-chunked-native-e2e-smoke",
        "make verify-streaming-failure-cache-e2e"
      ]
    },
    "release-quality": {
      "phase": "umbrella",
      "commands": [
        "make harness-check-full"
      ]
    },
    "coverage-gate": {
      "phase": "focused-semantic",
      "commands": [
        "make coverage-gate"
      ]
    },
    "release-governance-060": {
      "phase": "focused-semantic",
      "commands": [
        "make release-gates-check-060"
      ]
    },
    "e2e-harness-rust": {
      "phase": "focused-semantic",
      "commands": [
        "make test-e2e-rust"
      ]
    },
    "packaging-e2e": {
      "phase": "umbrella",
      "commands": [
        "dpkg-deb --info dist/nginx-markdown-module.deb",
        "rpm -qip dist/nginx-markdown-module.rpm",
        "helm lint charts/nginx-markdown"
      ],
      "notes": "commands validate existing artifacts; build steps are in CI workflows release-deb.yml, release-rpm.yml, and release-packages.yml"
    }
  },
